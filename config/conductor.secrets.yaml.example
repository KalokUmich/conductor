# Conductor Secrets Configuration
# Copy this file to conductor.secrets.yaml and fill in your API keys
#
# IMPORTANT: conductor.secrets.yaml should NEVER be committed to git!
# It is already included in .gitignore.
#
# Usage:
#   cp config/conductor.secrets.yaml.example config/conductor.secrets.yaml
#   # Then edit conductor.secrets.yaml with your actual API keys

# =============================================================================
# Database Credentials
# =============================================================================
# Used by both the backend and Liquibase migrations.
# Must match the values in docker/.env (POSTGRES_USER, POSTGRES_PASSWORD).
postgres:
  user: "conductor"
  password: "conductor"

# Redis (leave password empty for no auth, which is the default for local dev)
redis:
  password: ""

# =============================================================================
# AI Provider Credentials
# =============================================================================
# Configure API keys for the AI providers you want to use.
# Leave sections empty or remove them to disable that provider.

ai_providers:
  # Anthropic API (Direct)
  # Get your API key from: https://console.anthropic.com/settings/keys
  anthropic:
    api_key: "sk-ant-api03-YOUR_API_KEY_HERE"

  # AWS Bedrock
  # Uses AWS credentials to access Claude models via Bedrock
  # Create an IAM user with Bedrock access and generate access keys
  aws_bedrock:
    access_key_id: "AKIA..."
    secret_access_key: "YOUR_SECRET_ACCESS_KEY"
    # Optional: session token for temporary credentials (STS)
    session_token: ""
    # AWS region where Bedrock is available
    region: "eu-west-2"

  # OpenAI API
  # Get your API key from: https://platform.openai.com/api-keys
  openai:
    api_key: "sk-YOUR_API_KEY_HERE"
    # Optional: organization ID for usage tracking
    organization: ""

  # Alibaba Cloud DashScope (Qwen models, OpenAI-compatible)
  # Get your API key from: https://dashscope.console.aliyun.com/
  alibaba:
    api_key: "sk-YOUR_DASHSCOPE_API_KEY_HERE"
    # base_url defaults to Singapore region; change for other regions:
    #   Beijing:   https://dashscope.aliyuncs.com/compatible-mode/v1
    #   Virginia:  https://dashscope-us.aliyuncs.com/compatible-mode/v1
    # base_url: "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"

  # Moonshot AI (Kimi models, OpenAI-compatible)
  # Get your API key from: https://platform.moonshot.ai/
  moonshot:
    api_key: "sk-YOUR_MOONSHOT_API_KEY_HERE"
    # base_url: "https://api.moonshot.ai/v1"

# =============================================================================
# Google SSO Credentials
# =============================================================================
google_sso:
  client_id: "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
  client_secret: "YOUR_GOOGLE_CLIENT_SECRET"

# =============================================================================
# Ngrok Credentials
# =============================================================================
ngrok:
  authtoken: "YOUR_NGROK_AUTHTOKEN_HERE"

# =============================================================================
# Langfuse Observability
# =============================================================================
# These must match the auto-provisioned keys in docker/.env:
#   LANGFUSE_INIT_PROJECT_PUBLIC_KEY / LANGFUSE_INIT_PROJECT_SECRET_KEY
# Default dev values below work out of the box with `make langfuse-up`.
# Login: admin@conductor.dev / conductor  (http://localhost:3001)
langfuse:
  public_key: "pk-lf-conductor-dev"
  secret_key: "sk-lf-conductor-dev"

# =============================================================================
# Jira Integration (Atlassian OAuth 2.0)
# =============================================================================
# Create an app at https://developer.atlassian.com/console/myapps/
# Required scopes: read:jira-work, write:jira-work, read:jira-user, offline_access
# Callback URL: {your_backend_url}/api/integrations/jira/callback
jira:
  client_id: "YOUR_JIRA_CLIENT_ID"
  client_secret: "YOUR_JIRA_CLIENT_SECRET"
