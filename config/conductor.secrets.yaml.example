# Conductor Secrets Configuration
# Copy this file to conductor.secrets.yaml and fill in your API keys
#
# IMPORTANT: conductor.secrets.yaml should NEVER be committed to git!
# It is already included in .gitignore.
#
# Usage:
#   cp config/conductor.secrets.yaml.example config/conductor.secrets.yaml
#   # Then edit conductor.secrets.yaml with your actual API keys

# =============================================================================
# AI Provider Credentials
# =============================================================================
# Configure API keys for the AI providers you want to use.
# Leave sections empty or remove them to disable that provider.

ai_providers:
  # Anthropic API (Direct)
  # Get your API key from: https://console.anthropic.com/settings/keys
  anthropic:
    api_key: "sk-ant-api03-YOUR_API_KEY_HERE"

  # AWS Bedrock
  # Uses AWS credentials to access Claude models via Bedrock
  # Create an IAM user with Bedrock access and generate access keys
  aws_bedrock:
    access_key_id: "AKIAIOSFODNN7EXAMPLE"
    secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
    # Optional: session token for temporary credentials (STS)
    session_token: ""
    # AWS region where Bedrock is available
    region: "us-east-1"

  # OpenAI API
  # Get your API key from: https://platform.openai.com/api-keys
  openai:
    api_key: "sk-YOUR_API_KEY_HERE"
    # Optional: organization ID for usage tracking
    organization: ""

# =============================================================================
# Embedding, Reranking & Search Credentials
# =============================================================================
# These credentials are used by the LiteLLM embedding provider and reranking.
# AWS credentials are shared with the ai_providers section above.
#
# Only configure the providers you actually use. The embedding_model setting
# in conductor.settings.yaml determines which credentials are needed:
#
#   "bedrock/cohere.embed-v4:0"   → aws section
#   "text-embedding-3-small"      → openai section
#   "voyage/voyage-code-3"        → voyage section
#   "mistral/codestral-embed-2505" → mistral section
#   "cohere/embed-english-v3.0"   → cohere section
#   "sbert/..."                   → no credentials needed (local)

# AWS credentials for Bedrock embedding + reranking
# (reuses ai_providers.aws_bedrock credentials if set, OR use these)
aws:
  access_key_id: "AKIAIOSFODNN7EXAMPLE"
  secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
  region: "us-east-1"

# OpenAI embedding credentials (reuses ai_providers.openai if set)
openai:
  api_key: "sk-YOUR_API_KEY_HERE"

# Voyage AI — code-specialised embeddings (voyage-code-3)
# Get your API key from: https://dash.voyageai.com/
voyage:
  api_key: "pa-YOUR_API_KEY_HERE"

# Mistral AI — Codestral Embed
# Get your API key from: https://console.mistral.ai/api-keys
mistral:
  api_key: "YOUR_API_KEY_HERE"

# Cohere — Embedding + Rerank API (rerank-v3.5)
# Get your API key from: https://dashboard.cohere.com/api-keys
# Needed for: cohere reranking (direct API) or cohere embedding (direct)
# NOT needed if using Bedrock variants (bedrock/cohere.embed-v4:0)
cohere:
  api_key: "YOUR_API_KEY_HERE"

# =============================================================================
# Google SSO Credentials
# =============================================================================
google_sso:
  client_id: "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
  client_secret: "YOUR_GOOGLE_CLIENT_SECRET"

# =============================================================================
# Ngrok Credentials
# =============================================================================
ngrok:
  authtoken: "YOUR_NGROK_AUTHTOKEN_HERE"
