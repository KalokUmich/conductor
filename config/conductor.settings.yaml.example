# Conductor Settings Configuration
# Copy this file to conductor.settings.yaml and customize your settings
#
# This file contains non-sensitive settings and CAN be committed to git.
# For API keys and secrets, use conductor.secrets.yaml (gitignored).
#
# Usage:
#   cp config/conductor.settings.yaml.example config/conductor.settings.yaml
#   # Then edit conductor.settings.yaml with your preferences

# =============================================================================
# Server Configuration
# =============================================================================
server:
  host: "0.0.0.0"
  port: 8000
  debug: false
  reload: false
  log_level: "info"
  allowed_origins:
    - "http://localhost:3000"
    - "http://localhost:3001"
    - "http://localhost:5173"
    - "vscode-webview://*"

  # Public URL for external access (set by ngrok or other tunnel service)
  # When ngrok is enabled, the live tunnel URL takes priority over this value.
  # Leave empty to use localhost (only works when NOT in VS Code Remote-WSL).
  public_url: ""

# =============================================================================
# Ngrok Settings (non-secrets)
# =============================================================================
# Note: Ngrok authtoken is in conductor.secrets.yaml
ngrok:
  # Region (us, eu, ap, au, sa, jp, in)
  region: "us"

  # Enable ngrok tunnel on startup
  enabled: false

# =============================================================================
# PostgreSQL (OLTP — credentials in conductor.secrets.yaml)
# Env var DATABASE_URL overrides the built URL entirely.
# =============================================================================
postgres:
  host: "localhost"
  port: 5432
  database: "conductor"
  pool_size: 10
  max_overflow: 20

# =============================================================================
# Redis (chat state — credentials in conductor.secrets.yaml)
# Env var REDIS_URL overrides the built URL entirely.
# =============================================================================
redis:
  host: "localhost"
  port: 6379
  db: 0
  prefix: "conductor:"

# =============================================================================
# Authentication
# =============================================================================
auth:
  token_expire_minutes: 60
  refresh_expire_days: 7
  require_email_verify: false

# =============================================================================
# Rooms
# =============================================================================
rooms:
  max_participants: 50
  max_rooms_per_user: 10
  session_timeout_minutes: 120
  enable_persistence: true

# =============================================================================
# AWS SSO Configuration
# =============================================================================
# Enable SSO login for user identification via AWS IAM Identity Center.
sso:
  enabled: false
  start_url: "https://d-xxxxxxxxxx.awsapps.com/start"
  region: "us-east-1"

# =============================================================================
# Google SSO Configuration
# =============================================================================
# Requires client_id and client_secret in conductor.secrets.yaml.
google_sso:
  enabled: false

# =============================================================================
# AI Summary Configuration
# =============================================================================
summary:
  enabled: true
  # Must match an id from ai_models below
  default_model: "claude-sonnet-4-6-bedrock"

# =============================================================================
# AI Provider Settings
# =============================================================================
# Enable/disable providers. Even if enabled here, providers need valid API keys
# in conductor.secrets.yaml to function.
ai_provider_settings:
  anthropic_enabled: true
  aws_bedrock_enabled: true
  openai_enabled: true
  alibaba_enabled: false       # Alibaba DashScope (Qwen models, OpenAI-compatible)
  moonshot_enabled: false       # Moonshot AI (Kimi models, OpenAI-compatible)

# =============================================================================
# AI Models Configuration
# =============================================================================
# Define available models for each provider.
# Only models for enabled providers with valid API keys will be usable.
#
# Special flags:
#   explorer: true    — Can be used as sub-agent model
#   explorer: true    — Can be used as sub-agent model
ai_models:
  # ---- Claude (Bedrock) ----
  - id: "claude-sonnet-4-6-bedrock"
    provider: "aws_bedrock"
    model_name: "eu.anthropic.claude-sonnet-4-6"
    display_name: "Claude Sonnet 4.6 (Bedrock EU)"
    enabled: true
    explorer: true


  - id: "claude-haiku-4-5-bedrock"
    provider: "aws_bedrock"
    model_name: "eu.anthropic.claude-haiku-4-5-20251001-v1:0"
    display_name: "Claude Haiku 4.5 (Bedrock EU)"
    enabled: true

    explorer: true

  # ---- Claude (Anthropic Direct) ----
  - id: "claude-sonnet-4-anthropic"
    provider: "anthropic"
    model_name: "claude-sonnet-4-20250514"
    display_name: "Claude Sonnet 4 (Anthropic)"
    enabled: true

  # ---- OpenAI ----
  - id: "gpt-4o"
    provider: "openai"
    model_name: "gpt-4o"
    display_name: "GPT-4o"
    enabled: true

  - id: "gpt-4o-mini"
    provider: "openai"
    model_name: "gpt-4o-mini"
    display_name: "GPT-4o Mini"
    enabled: true


  # ---- Alibaba / Qwen (DashScope, OpenAI-compatible) ----
  # Requires alibaba_enabled: true and a DashScope API key in secrets
  - id: "qwen3-max"
    provider: "alibaba"
    model_name: "qwen3-max"
    display_name: "Qwen3 Max (DashScope)"
    enabled: true

  - id: "qwen3.5-plus"
    provider: "alibaba"
    model_name: "qwen3.5-plus"
    display_name: "Qwen3.5 Plus (DashScope)"
    enabled: true
    explorer: true

  - id: "qwen3.5-flash"
    provider: "alibaba"
    model_name: "qwen3.5-flash"
    display_name: "Qwen3.5 Flash (DashScope)"
    enabled: true

    explorer: true

  - id: "qwen3-coder-plus"
    provider: "alibaba"
    model_name: "qwen3-coder-plus"
    display_name: "Qwen3 Coder Plus (DashScope)"
    enabled: true

  - id: "qwen3-coder-flash"
    provider: "alibaba"
    model_name: "qwen3-coder-flash"
    display_name: "Qwen3 Coder Flash (DashScope)"
    enabled: true

    explorer: true

  # ---- Moonshot / Kimi (OpenAI-compatible) ----
  # Requires moonshot_enabled: true and a Moonshot API key in secrets
  - id: "kimi-k2.5"
    provider: "moonshot"
    model_name: "kimi-k2.5"
    display_name: "Kimi K2.5 (Moonshot)"
    enabled: true

# =============================================================================
# Prompt Configuration
# =============================================================================
prompt:
  output_mode: "unified_diff"

# =============================================================================
# Change Limits Configuration
# =============================================================================
change_limits:
  max_files_per_request: 10
  max_total_lines: 2000
  auto_apply:
    max_lines: 50

# =============================================================================
# Logging Configuration
# =============================================================================
logging:
  audit_enabled: true
  audit_path: "backend/audit_logs.db"

# =============================================================================
# Git Workspace Settings
# =============================================================================
git_workspace:
  enabled: true
  workspaces_dir: "./workspaces"
  git_auth_mode: "token"           # "token" (Mode A) or "delegate" (Mode B)
  credential_ttl_seconds: 3600
  max_worktrees_per_repo: 20
  cleanup_on_room_close: true

# =============================================================================
# Session Trace Settings
# =============================================================================
# Records per-query metrics (tokens, latencies, tool calls) for offline analysis.
trace:
  enabled: true
  backend: "database"                       # "local" (JSON files) or "database" (Postgres)
  local_path: ".conductor/session_traces"   # fallback when database is unavailable

# =============================================================================
# Langfuse Observability
# =============================================================================
# Self-hosted Langfuse via: make langfuse-up  (http://localhost:3001)
# User/org/project are auto-provisioned on first startup (see docker/.env).
# Dev defaults — add these to conductor.secrets.yaml:
#   langfuse:
#     public_key: "pk-lf-conductor-dev"
#     secret_key: "sk-lf-conductor-dev"
# Login: admin@conductor.dev / conductor
langfuse:
  enabled: true
  host: "http://localhost:3001"

# =============================================================================
# Jira Integration
# =============================================================================
# Atlassian OAuth 2.0 (3LO) for Jira Cloud.
# Create an OAuth 2.0 app at https://developer.atlassian.com/console/myapps/
# Set callback URL to: {your_backend_url}/api/integrations/jira/callback
# client_id and client_secret go in conductor.secrets.yaml
jira:
  enabled: true
  branch_formats:
    feature: "feature/{ticket}-{content}"
    bugfix: "bugfix/{ticket}-{content}"
  # Restrict project list to these keys. Empty list = show all projects.
  allowed_projects: []
  # Team UUIDs for customfield_10001 (Atlassian Teams).
  # Find each UUID at: https://team.atlassian.com/people/team/{uuid}
  teams: []
