        "required": [
          "test_file",
          "test_function",
          "line_number"
        ],
        "title": "TestMatch",
        "type": "object"
      }
    },
    "test_outline": {
      "input_schema": {
        "properties": {
          "path": {
            "description": "Relative path to a test file.",
            "title": "Path",
            "type": "string"
          }
        },
        "required": [
          "path"
        ],
        "title": "TestOutlineParams",
        "type": "object"
      },
      "output_type": "list",
      "output_item_fields": [
        "name",
        "kind",
        "line_number",
        "end_line",
        "mocks",
        "assertions",
        "fixtures"
      ],
      "output_item_schema": {
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "kind": {
            "title": "Kind",
            "type": "string"
          },
          "line_number": {
            "title": "Line Number",
            "type": "integer"
          },
          "end_line": {
            "default": 0,
            "title": "End Line",
            "type": "integer"
          },
          "mocks": {
            "items": {
              "type": "string"
            },
            "title": "Mocks",
            "type": "array"
          },
          "assertions": {
            "items": {
              "type": "string"
            },
            "title": "Assertions",
            "type": "array"
          },
          "fixtures": {
            "items": {
              "type": "string"
            },
            "title": "Fixtures",
            "type": "array"
          }
        },
        "required": [
          "name",
          "kind",
          "line_number"
        ],
        "title": "TestOutlineEntry",
        "type": "object"
      }
    },
    "trace_variable": {
      "input_schema": {
        "properties": {
          "variable_name": {
            "description": "Name of the variable to trace (e.g. 'loan_id').",
            "title": "Variable Name",
            "type": "string"
          },
          "file": {
            "description": "Relative file path containing the variable.",
            "title": "File",
            "type": "string"
          },
          "function_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Function containing the variable. If omitted, the first function referencing it is used.",
            "title": "Function Name"
          },
          "direction": {
            "default": "forward",
            "description": "'forward' = trace where the value flows to (call sites, ORM/SQL sinks). 'backward' = trace where the value comes from (callers, HTTP/config sources).",
            "title": "Direction",
            "type": "string"
          }
        },
        "required": [
          "variable_name",
          "file"
        ],
        "title": "TraceVariableParams",
        "type": "object"
      },
      "output_type": "dict",
      "output_item_fields": [
        "forward",
        "backward"
      ]
    },
    "compressed_view": {
      "input_schema": {
        "properties": {
          "file_path": {
            "description": "Relative path to the file to analyze.",
            "title": "File Path",
            "type": "string"
          },
          "focus": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Optional: focus on a specific symbol name (substring match).",
            "title": "Focus"
          }
        },
        "required": [
          "file_path"
        ],
        "title": "CompressedViewParams",
        "type": "object"
      },
      "output_type": "dict",
      "output_item_fields": [
        "content",
        "path",
        "total_lines",
        "symbol_count"
      ]
    },
    "module_summary": {
      "input_schema": {
        "properties": {
          "module_path": {
            "description": "Relative path to the module directory (e.g. 'app/auth').",
            "title": "Module Path",
            "type": "string"
          }
        },
        "required": [
          "module_path"
        ],
        "title": "ModuleSummaryParams",
        "type": "object"
      },
      "output_type": "dict",
      "output_item_fields": [
        "content",
        "file_count",
        "loc"
      ]
    },
    "expand_symbol": {
      "input_schema": {
        "properties": {
          "symbol_name": {
            "description": "Name of the symbol to expand (e.g. 'PaymentService' or 'process_payment').",
            "title": "Symbol Name",
            "type": "string"
          },
          "file_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "File containing the symbol. If omitted, searches the workspace.",
            "title": "File Path"
          }
        },
        "required": [
          "symbol_name"
        ],
        "title": "ExpandSymbolParams",
        "type": "object"
      },
      "output_type": "dict",
      "output_item_fields": [
        "symbol_name",
        "kind",
        "file_path",
        "start_line",
        "end_line",
        "signature",
        "source"
      ]
    },
    "detect_patterns": {
      "input_schema": {
        "properties": {
          "path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Relative path within workspace to scan (file or directory). Omit to scan the whole workspace.",
            "title": "Path"
          },
          "categories": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Pattern categories to detect. Omit to detect all. Options: webhook, queue, retry, lock, check_then_act, transaction, token_lifecycle, side_effect_chain.",
            "title": "Categories"
          },
          "max_results": {
            "default": 50,
            "maximum": 200,
            "minimum": 1,
            "title": "Max Results",
            "type": "integer"
          }
        },
        "title": "DetectPatternsParams",
        "type": "object"
      },
      "output_type": "list",
      "output_item_fields": [
        "file_path",
        "line",
        "category",
        "pattern",
        "snippet"
      ]
    },
    "run_test": {
      "input_schema": {
        "properties": {
          "test_file": {
            "description": "Relative path to the test file to run (e.g. 'tests/test_auth.py').",
            "title": "Test File",
            "type": "string"
          },
          "test_name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Specific test function or class to run (e.g. 'test_timeout', 'TestAuth::test_login'). If omitted, runs the whole file.",
            "title": "Test Name"
          },
          "timeout": {
            "default": 30,
            "description": "Max seconds to wait for the test run (default: 30).",
            "maximum": 60,
            "minimum": 5,
            "title": "Timeout",
            "type": "integer"
          }
        },
        "required": [
          "test_file"
        ],
        "title": "RunTestParams",
        "type": "object"
      },
      "output_type": "dict",
      "output_item_fields": [
        "passed",
        "output",
        "failures"
      ]
    }
  }
