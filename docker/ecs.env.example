# ECS deployment environment variables
# Copy to ecs.env and fill in real values:
#   cp docker/ecs.env.example docker/ecs.env

# ---------- RDS ----------
RDS_HOST=mydb.xxxxxxxxxxxx.ap-northeast-1.rds.amazonaws.com
RDS_PORT=5432
POSTGRES_USER=conductor
POSTGRES_PASSWORD=change-me
POSTGRES_DB=conductor

# ---------- ElastiCache ----------
ELASTICACHE_HOST=my-redis.xxxxxxxxxxxx.apne1.cache.amazonaws.com
ELASTICACHE_PORT=6379

# ---------- Langfuse ----------
LANGFUSE_NEXTAUTH_SECRET=change-me-random-string
LANGFUSE_SALT=change-me-random-string
LANGFUSE_URL=https://langfuse.your-domain.com
