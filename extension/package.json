{
  "name": "ai-collab",
  "publisher": "conductor",
  "displayName": "AI Collab",
  "description": "AI collaboration extension for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionPack": [
    "ms-python.python",
    "ms-python.vscode-pylance",
    "golang.go",
    "rust-lang.rust-analyzer",
    "redhat.java"
  ],
  "activationEvents": [
    "onView:aiCollabView",
    "onFileSystem:conductor",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-collab-sidebar",
          "title": "AI Collab",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ai-collab-sidebar": [
        {
          "type": "webview",
          "id": "aiCollabView",
          "name": "Chat",
          "visibility": "visible"
        }
      ]
    },
    "virtualWorkspaces": {
      "supported": "limited",
      "description": "Conductor remote workspaces via conductor:// URI scheme"
    },
    "commands": [
      {
        "command": "ai-collab.openPanel",
        "title": "AI Collab: Open Panel"
      },
      {
        "command": "conductor.searchWorkspace",
        "title": "Conductor: Search Remote Workspace"
      },
      {
        "command": "conductor.showWorkflow",
        "title": "Conductor: View Agent Workflows"
      },
      {
        "command": "conductor.jiraConnect",
        "title": "Conductor: Connect to Jira"
      },
      {
        "command": "conductor.jiraDisconnect",
        "title": "Conductor: Disconnect Jira"
      },
      {
        "command": "conductor.compareTools",
        "title": "Conductor: Compare Local Tools (LSP vs grep vs tree-sitter)"
      }
    ],
    "configuration": {
      "title": "AI Collab",
      "properties": {
        "aiCollab.role": {
          "type": "string",
          "enum": [
            "lead",
            "member"
          ],
          "default": "member",
          "description": "Your role in the AI collaboration. 'lead' has access to advanced features like Create Summary, Generate Changes, and Auto Apply. 'member' can only chat."
        },
        "aiCollab.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Backend server URL. Use ngrok URL for remote access."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ts && npm run compile:webview && npm run compile:css",
    "compile:ts": "npx tsc -p ./",
    "compile:webview": "node webview-ui/esbuild.mjs --production",
    "compile:css": "tailwindcss -i ./media/input.css -o ./media/tailwind.css --minify",
    "watch:webview": "node webview-ui/esbuild.mjs --watch",
    "pretest": "npm run compile:ts",
    "test": "node --test out/tests/*.test.js",
    "test:webview": "npx vitest run --config webview-ui/vitest.config.ts",
    "test:all": "npm test && npm run test:webview",
    "lint": "eslint src --ext ts",
    "build:css": "tailwindcss -i ./media/input.css -o ./media/tailwind.css --minify"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.x",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^11.7.0",
    "js-tiktoken": "^1.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.3",
    "web-tree-sitter": "0.26.7"
  }
}
