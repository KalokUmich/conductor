# Conductor Project .gitignore

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
*.manifest
*.spec

# PyInstaller
*.manifest
*.spec

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# VS Code Extension
# =============================================================================
extension/out/
extension/*.vsix
*.vsix

# =============================================================================
# IDE
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Database
# =============================================================================
*.sqlite
*.db

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# Environment & Secrets
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key

# Local config overrides — NEVER committed
# conductor.secrets.yaml is committed (safe defaults only, no real keys)
# conductor.secrets.local.yaml has your real credentials (gitignored)
# conductor.settings.local.yaml has your environment overrides (gitignored)
config/conductor.secrets.local.yaml
config/conductor.settings.local.yaml
conductor.secrets.local.yaml
conductor.settings.local.yaml
# Docker env file with database credentials
docker/.env
# Tool comparison generated outputs
eval/tool_baseline.json
eval/tool_lsp_results.json
tool_lsp_results.json
# Legacy config file (replaced by separate secrets/settings files)
config/conductor.yaml
conductor.yaml
# Note: conductor.settings.yaml is NOT gitignored - it contains safe defaults

# =============================================================================
# Conductor Workspace Storage (per-workspace local data)
# =============================================================================
.conductor/

# =============================================================================
# RAG Runtime Data (FAISS indices, per-workspace, machine-local)
# =============================================================================
backend/data/

# =============================================================================
# Git Workspace Runtime Data (bare clones, worktrees, token cache)
# These are large local git repos + sensitive credentials — never commit.
# =============================================================================
backend/workspaces/
workspaces/
# Explicit pattern for the repo-token SQLite cache (contains PATs in plaintext)
token_cache.db

# =============================================================================
# Build & Temp Files
# =============================================================================
tmp/
temp/
*.tmp
*.bak

# =============================================================================
# Documentation
# =============================================================================
# Keep documentation, but ignore generated docs
docs/_build/
site/

